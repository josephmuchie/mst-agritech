# MST Agritech API — Railway variable template for service: mst-agritech-api
#
# HOW TO USE
# 1. Railway Dashboard → mst-agritech-api → Variables → Raw Editor
# 2. Paste the NON-COMMENT lines below (adjust service names if yours differ)
# 3. Generate secrets:  openssl rand -hex 32
#
# Postgres + Redis: the app auto-reads DATABASE_URL / PG* / REDIS* from linked
# services via CloudEnvironmentPostProcessor. Only add DB_* below if auto-detect fails.
#
# Service names in ${{...}} must match your Railway project (default: Postgres, Redis).

# ── Secrets (required — replace with generated values) ─────────────────────
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JASYPT_PASSWORD=REPLACE_WITH_openssl_rand_hex_32

# ── Public URLs ───────────────────────────────────────────────────────────
FRONTEND_URL=https://agritech.mst.co.zw
API_BASE_URL=https://agritech-api.mst.co.zw

# ── Optional: explicit Railway references (uncomment if auto-detect fails) ───
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_NAME=${{Postgres.PGDATABASE}}
# DB_USER=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}
# REDIS_HOST=${{Redis.REDISHOST}}
# REDIS_PORT=${{Redis.REDISPORT}}
# REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

# ── Do NOT set (managed by Railway + app) ─────────────────────────────────
# PORT              — Railway injects; app maps to SERVER_PORT automatically
# SERVER_PORT       — leave unset on Railway
# RAILWAY_*         — system-provided
