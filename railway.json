{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/core-api/Dockerfile",
    "watchPatterns": [
      "backend/core-api/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "overlapSeconds": 30,
    "drainingSeconds": 15,
    "runtime": "V2",
    "numReplicas": 1
  }
}
