# Copy to .env and fill in before running docker compose

# Database
DB_NAME=agritech_db
DB_USER=agritech
DB_PASSWORD=change_me_strong_password

# API
API_PORT=8081
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_64_characters
JASYPT_PASSWORD=change_me_jasypt_secret

# URLs (production)
FRONTEND_URL=https://your-app.vercel.app
API_BASE_URL=https://api.yourdomain.com

# Optional: pgAdmin (dev only, docker-compose.yml)
POSTGRES_PASSWORD=agritech_dev_pass
PGADMIN_EMAIL=admin@mstagritech.co.zw
PGADMIN_PASSWORD=pgadmin_pass
